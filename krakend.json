{
  "version": 3,
  "debug_endpoint": true,
  "echo_endpoint": true,
  "host": ["http://localhost:8080/"],
  "extra_config": {
    "server/static-filesystem": {
      "prefix": "/media/",
      "path": "./"
    }
  },
  "endpoints": [
    {
      "endpoint": "/xml",
      "output_encoding": "xml",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/media/test.xml",
          "encoding": "xml"
        }
      ]
    },
    {
      "endpoint": "/no-op",
      "output_encoding": "no-op",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/media/test.xml",
          "encoding": "no-op"
        }
      ]
    }
  ]
}
